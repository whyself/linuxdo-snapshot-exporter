{
  "manifest_version": 3,
  "name": "Linux.do Snapshot Exporter",
  "version": "0.1.0",
  "description": "Export Linux.do topic content to Markdown.",
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://linux.do/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Snapshot Exporter"
  },
  "content_scripts": [
    {
      "matches": [
        "https://linux.do/t/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
